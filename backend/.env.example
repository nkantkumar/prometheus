# Siemens & Deutsche Bank Agentic Procurement Configuration Example
# Copy this file to .env and fill in your details

# The Google API Key is required to run the Gemini Model (gemini-1.5-flash).
# If this is left blank or not provided, the application will fallback to a simulated mock LLM.
GOOGLE_API_KEY=your_gemini_api_key_here

# Backend Server Settings
PORT=8000
HOST=0.0.0.0
